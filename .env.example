# Gmail Cleaner Configuration

# Delete all emails before this date
# Accepts: "2024" (Jan 1, 2024), "2024-06-15", "2024/06/15"
DELETE_BEFORE_DATE=2024

# Number of latest emails to label as "Keep" before deletion
KEEP_LATEST_COUNT=1000

# Path to Google OAuth credentials JSON (downloaded from Cloud Console)
GOOGLE_CREDENTIALS_PATH=credentials.json

# Path to store OAuth token (auto-generated after first auth)
GOOGLE_TOKEN_PATH=token.json

# Batch size for API calls (max 1000)
BATCH_SIZE=1000

# Default to dry-run mode (true = preview only, false = actually delete)
DRY_RUN=true

# --- LLM Provider Configuration (for Streamlit chat UI) ---

# Anthropic (default)
ANTHROPIC_API_KEY=

# OpenAI
OPENAI_API_KEY=

# Azure OpenAI
AZURE_OPENAI_API_KEY=
AZURE_OPENAI_ENDPOINT=
AZURE_OPENAI_API_VERSION=2024-02-01
AZURE_OPENAI_DEPLOYMENT_NAME=

# AWS Bedrock
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
